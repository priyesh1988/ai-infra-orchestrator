{
  "title": "AI Infra Orchestrator (Stub)",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests (by status)",
      "targets": [
        {
          "expr": "sum by (status) (rate(aio_requests_total[5m]))"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Latency (p95)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(aio_request_latency_seconds_bucket[5m])))"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 9
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  }
}